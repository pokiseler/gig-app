# Server
PORT=5000
NODE_ENV=development

# Database
# Development: use your local MongoDB URI (Compass)
# Production:  use your Atlas connection string
MONGO_URI=mongodb://localhost:27017/gigapp
MONGO_TIMEOUT_MS=10000
MONGO_MAX_POOL_SIZE=10

# Auth
JWT_SECRET=replace-with-a-long-random-secret

# CORS — comma-separated list of allowed frontend origins.
# Development default (when unset): http://localhost:3000
# Production example: https://your-app.vercel.app
CORS_ORIGINS=

# Rate limits
RATE_LIMIT_MAX=600
AUTH_RATE_LIMIT_MAX=30

# Points rules
GIG_OPENING_COST=30
GIG_COMPLETION_REWARD=30

# Optional
PLATFORM_FEE_PERCENT=0
REQUIRE_MONGO_TRANSACTIONS=false
