# Server
PORT=5000

# Database
MONGO_URI=mongodb+srv://username:password@cluster-name.mongodb.net/gig-app?retryWrites=true&w=majority
MONGO_TIMEOUT_MS=10000
MONGO_MAX_POOL_SIZE=10

# Auth
JWT_SECRET=replace-with-a-long-random-secret

# CORS (comma-separated list)
# Example: https://your-app.vercel.app,https://www.your-domain.co.il
CORS_ORIGINS=http://localhost:3000

# Rate limits (balanced defaults)
RATE_LIMIT_MAX=600
AUTH_RATE_LIMIT_MAX=30

# Points rules
GIG_OPENING_COST=25
GIG_COMPLETION_REWARD=25

# Optional
PLATFORM_FEE_PERCENT=0
