{
  "info": {
    "name": "Gig API Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth - Register Provider",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "const jsonData = pm.response.json();",
              "pm.test('Registration returns token', function () {",
              "    pm.expect(jsonData.token).to.be.a('string');",
              "});",
              "pm.environment.set('providerToken', jsonData.token);",
              "pm.environment.set('providerUserId', jsonData.user._id);",
              "pm.environment.set('authTestEmail', jsonData.user.email);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Postman Provider\",\n  \"email\": \"postman_provider_{{$timestamp}}@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"provider\",\n  \"location\": {\n    \"city\": \"Bat Yam\"\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "register"
          ]
        }
      }
    },
