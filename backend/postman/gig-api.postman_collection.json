    {
      "name": "Create Gig - Valid Offering",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "const jsonData = pm.response.json();",
              "pm.test('Gig created successfully message exists', function () {",
              "    pm.expect(jsonData.message).to.eql('Gig created successfully.');",
              "});",
              "pm.test('Returned gig type is offering', function () {",
              "    pm.expect(jsonData.gig.type).to.eql('offering');",
              "});",
              "pm.environment.set('createdGigId', jsonData.gig._id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{providerToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Postman Plumbing Test\",\n  \"description\": \"Testing create gig from Postman collection\",\n  \"type\": \"offering\",\n  \"category\": \"Plumbing\",\n  \"price\": 250,\n  \"location\": {\n    \"city\": \"Bat Yam\",\n    \"address\": \"Herzl 10\"\n  },\n  \"images\": [\n    \"https://example.com/job-photo.jpg\"\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/gigs",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "gigs"
          ]
        }
      }
    },
    {
      "name": "Get All Gigs - Filter And Search",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "const jsonData = pm.response.json();",
              "pm.test('At least one gig is returned', function () {",
              "    pm.expect(jsonData.total).to.be.above(0);",
              "});",
              "pm.test('Returned gigs match offering filter', function () {",
              "    pm.expect(jsonData.gigs.every(function (gig) { return gig.type === 'offering'; })).to.eql(true);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/gigs?type=offering&location=Bat%20Yam&search=Plumbing&minPrice=200&maxPrice=300&sortBy=createdAt&order=desc",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "gigs"
          ],
          "query": [
            {
              "key": "type",
              "value": "offering"
            },
            {
              "key": "location",
              "value": "Bat Yam"
            },
            {
              "key": "search",
              "value": "Plumbing"
            },
            {
              "key": "minPrice",
              "value": "200"
            },
            {
              "key": "maxPrice",
              "value": "300"
            },
            {
              "key": "sortBy",
              "value": "createdAt"
            },
            {
              "key": "order",
              "value": "desc"
            }
          ]
        }
      }
    },
    {
      "name": "Create Gig - Invalid Provider Wanted",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 400', function () {",
              "    pm.response.to.have.status(400);",
              "});",
              "const jsonData = pm.response.json();",
              "pm.test('Business rule error is returned', function () {",
              "    pm.expect(jsonData.message).to.eql('Providers can only create offering gigs.');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{providerToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Invalid Provider Wanted Test\",\n  \"description\": \"This should fail\",\n  \"type\": \"wanted\",\n  \"category\": \"Testing\",\n  \"price\": 120\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/gigs",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "gigs"
          ]
        }
      }
    },
    {
      "name": "Update Gig - Owner Allowed",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "const jsonData = pm.response.json();",
              "pm.test('Updated message exists', function () {",
              "    pm.expect(jsonData.message).to.eql('Gig updated successfully.');",
              "});",
              "pm.test('Price was updated', function () {",
              "    pm.expect(jsonData.gig.price).to.eql(275);",
              "});",
              "pm.test('City was updated', function () {",
              "    pm.expect(jsonData.gig.location.city).to.eql('Holon');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{providerToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"price\": 275,\n  \"location\": {\n    \"city\": \"Holon\",\n    \"address\": \"Sokolov 5\"\n  },\n  \"images\": [\n    \"https://example.com/updated-job-photo.jpg\"\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/gigs/{{createdGigId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "gigs",
            "{{createdGigId}}"
          ]
        }
      }
    },
