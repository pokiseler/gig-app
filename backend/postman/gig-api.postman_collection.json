    {
      "name": "Get Created Gig",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "const jsonData = pm.response.json();",
              "pm.test('Fetched gig id matches created gig id', function () {",
              "    pm.expect(jsonData._id).to.eql(pm.environment.get('createdGigId'));",
              "});",
              "pm.test('Fetched gig contains the updated price', function () {",
              "    pm.expect(jsonData.price).to.eql(275);",
              "});"
            ]
